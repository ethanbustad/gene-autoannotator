{
  "gene_id": "TcCLB.507093.220",
  "name": "UBP1",
  "function": "orchestrates an RNA regulon to promote differentiation to infective forms (PMID 38758959); modulates the expression of several surface glycoproteins (PMID 36935010); binds to structural binding elements highly enriched in transcripts coding for surface cell virulence factors associated with the metacyclic trypomastigote developmental stage; regulates mRNA steady-state levels; involved in the formation of distinct regulatory complexes; may act with dual functionality in RNA metabolism (PMID 36935010); Modulates mRNA life cycle, organizes transcriptomes into regulons, targets glycoprotein mRNAs, increases abundance of target transcripts in polysome fraction (PMID 31113862); Translational repressor, promotes differentiation from non-infective epimastigotes to infective metacyclic trypomastigotes (PMID 29864162); Modulates mRNA stability and translational efficiency; binds to mRNA transcripts to form messenger ribonucleoprotein (mRNP) complexes (PMID 19063746); selects mRNAs with long 3\u2032 UTRs; binds in vitro to U-rich sequences (PMID 33536101); stabilization/degradation of mRNAs and protection of transcripts through their recruitment into cytoplasmic granules; shuttling between nucleus and cytoplasm; linking mRNA metabolism at both sides of the nuclear pore complex (PMID 19801539).",
  "functional_category": [
    "RNA-binding protein",
    "mRNA stabilization/degradation",
    "transcript protection"
  ],
  "drug_susc_impact": null,
  "infection_impact": "Increases infection potential (PMID 38758959, PMID 36935010, PMID 31113862, PMID 29864162).",

{
  "gene_id": "Rv2612c",
  "name": "pgsA1",
  "rv_id": "Rv2612c",
  "function": "Catalyzes the transfer of a mannosyl residue from GDP-Man to phosphatidyl-myo-inositol, playing a role in the regulation of cell wall biogenesis and inositol-derived cell wall component synthesis. It also activates ino1, which encodes inositol phosphate synthase, and is involved in mycothiol biosynthesis.",
  "functional_category": [
    "Transcriptional regulator",
    "Activator of ino1 and target genes involved in inositol-derived cell wall component synthesis"
  ],
  "drug_susc_impact": "Hypersensitivity to multidrug-resistant MTB strains against first-line anti-TB drugs under iron restriction.  May be a potential drug target.",
  "infection_impact": "Requirement for viability during macrophage infection and in mouse models of infection, leading to complete clearance of the lungs. Deletion leads to a complete loss of mycothiol biosynthesis.",
  "essential_in_vitro": true,
  "essential_in_vivo": true,
  "annotation_notes": "Multiple papers describe conflicting roles for this gene. Some papers indicate it is essential for in vitro and in vivo growth, while others describe it as a transcriptional regulator. The most recent and highest-scoring evidence supports a role as a transcriptional regulator and essential for in vivo viability.",
